{
  "name": "brevoppskrift-web-frontend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "tsc && vite build",
    "check-types": "tsc --noemit",
    "dev": "vite",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "lint-and-check-types": "${npm_execpath} run format && ${npm_execpath} run lint && ${npm_execpath} run stylelint && ${npm_execpath} run check-types",
    "preview": "vite preview",
    "stylelint:fix": "stylelint --fix '**/*.{tsx,css}'",
    "stylelint": "stylelint '**/*.{tsx,css}'"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@navikt/aksel-icons": "8.10.2",
    "@navikt/ds-css": "8.10.2",
    "@navikt/ds-react": "8.10.2",
    "@tanstack/react-query": "5.100.5",
    "@tanstack/react-router": "1.168.25",
    "axios": "1.16.0",
    "lodash": "4.18.1",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@navikt/aksel-stylelint": "8.10.2",
    "@tanstack/react-query-devtools": "5.100.5",
    "@tanstack/router-devtools": "1.166.13",
    "@tanstack/router-plugin": "1.167.28",
    "@types/lodash": "4.17.24",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "globals": "17.5.0",
    "lint-staged": "16.4.0",
    "postcss-styled-syntax": "0.7.1",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
