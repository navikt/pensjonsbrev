{
  "core": {
    "workingDir": ".",
    "actualDir": "./actual",
    "threshold": 0
  },
  "plugins": {
    "reg-simple-keygen-plugin": {
      "expectedKey": "main",
      "actualKey": "${ACTUAL_KEY}"
    },
    "reg-publish-gcs-plugin": {
      "bucketName": "no-nav-pensjonsbrev-reg-suit",
      "pathPrefix": "pdf-visual2"
    },
    "reg-notify-github-with-api-plugin": {
      "owner": "navikt",
      "repository": "pensjonsbrev",
      "privateToken": "$GITHUB_TOKEN"
    }
  }
}
