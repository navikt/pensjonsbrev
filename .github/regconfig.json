{
  "core": {
    "workingDir": ".",
    "actualDir": ".",
    "threshold": 0
  },
  "plugins": {
    "reg-keygen-git-hash-plugin": {
      "expectedKeyFromEnv": "REG_SUIT_EXPECTED_KEY"
    },
    "reg-publish-gcs-plugin": {
      "bucketName": "no-nav-pensjonsbrev-reg-suit",
