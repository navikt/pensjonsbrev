<configuration>
    <appender name="stdout_json" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="no.nav.pensjon.brev.skribenten.logging.NavJsonEncoder"/>
    </appender>
    <root level="INFO">
        <appender-ref ref="stdout_json"/>
    </root>
    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>
    <logger name="io.getunleash.repository.PollingFeatureFetcher" level="ERROR"/>
</configuration>
