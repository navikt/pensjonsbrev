{
  "name": "skribenten-web-frontend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "tsc && vite build",
    "check-types": "tsc --noemit",
    "cypress": "cypress open",
    "cypress:component": "cypress run --component -b chrome",
    "cypress:e2e": "start-server-and-test 'vite preview --port 4173' localhost:4173 'cypress run -b chrome --config baseUrl=http://localhost:4173'",
    "dev": "vite --host",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "lint-and-check-types": "${npm_execpath} run format && ${npm_execpath} run lint && ${npm_execpath} run stylelint && ${npm_execpath} run check-types",
    "preview": "vite preview",
    "stylelint": "stylelint '**/*.{tsx,css}'",
    "stylelint:fix": "stylelint --fix '**/*.{tsx,css}'",
    "test": "vitest --config ./vite.config.ts",
    "tsc:watch": "tsc --watch",
    "verify": "${npm_execpath} run lint-and-check-types && vitest run --config ./vite.config.ts && ${npm_execpath} run cypress:component && ${npm_execpath} run build && ${npm_execpath} run cypress:e2e"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@hookform/resolvers": "5.2.2",
    "@navikt/aksel-icons": "8.9.0",
    "@navikt/ds-css": "8.9.0",
    "@navikt/ds-react": "8.9.0",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "1.168.10",
    "axios": "1.14.0",
    "date-fns": "4.1.0",
    "dompurify": "3.3.3",
    "fuse.js": "7.1.0",
    "immer": "11.1.4",
    "lodash": "4.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-pdf": "10.4.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@navikt/aksel-stylelint": "8.9.0",
    "@tanstack/react-query-devtools": "5.95.2",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/router-vite-plugin": "1.166.27",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.24",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "cypress": "15.13.0",
    "happy-dom": "20.8.9",
    "jsdom": "29.0.1",
    "lint-staged": "16.4.0",
    "postcss-styled-syntax": "0.7.1",
    "start-server-and-test": "3.0.0",
    "stylelint": "17.3.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "overrides": {
    "cypress": {
      "qs": ">=6.14.1"
    }
  }
}
