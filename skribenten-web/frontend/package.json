{
  "name": "skribenten-web-frontend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "tsc && vite build",
    "check-types": "tsc --noemit",
    "dev": "vite --host",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "lint-and-check-types": "${npm_execpath} run format && ${npm_execpath} run lint && ${npm_execpath} run stylelint && ${npm_execpath} run check-types",
    "preview": "vite preview",
    "stylelint": "stylelint 'src/**/*.{tsx,css}'",
    "stylelint:fix": "stylelint --fix 'src/**/*.{tsx,css}'",
    "test": "vitest --config ./vite.config.ts",
    "tsc:watch": "tsc --watch",
    "verify": "${npm_execpath} run lint-and-check-types && vitest run --config ./vite.config.ts && ${npm_execpath} run e2e"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@hookform/resolvers": "5.4.0",
    "@navikt/aksel-icons": "8.11.0",
    "@navikt/ds-css": "8.11.0",
    "@navikt/ds-react": "8.11.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-router": "1.170.8",
    "axios": "1.16.1",
    "date-fns": "4.3.0",
    "dompurify": "3.4.9",
    "fuse.js": "7.3.0",
    "immer": "11.1.8",
    "lodash": "4.18.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "react-pdf": "10.4.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@navikt/aksel-stylelint": "8.11.0",
    "@playwright/test": "1.60.0",
    "@tanstack/react-query-devtools": "5.100.14",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-vite-plugin": "1.167.11",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.24",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "happy-dom": "20.9.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "postcss-styled-syntax": "0.7.1",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "openapi-typescript": "7.13.0",
    "vite": "8.0.16",
    "vitest": "4.1.7"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript",
      "js-yaml": "^4.2.0"
    }
  }
}
