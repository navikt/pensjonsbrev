{
  "name": "skribenten-web-frontend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "tsc && vite build",
    "check-types": "tsc --noemit",
    "dev": "vite --host",
    "e2e": "playwright test",
    "e2e:ui:dev": "playwright test --ui",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "lint-and-check-types": "${npm_execpath} run format && ${npm_execpath} run lint && ${npm_execpath} run stylelint && ${npm_execpath} run check-types",
    "preview": "vite preview",
    "stylelint": "stylelint '**/*.{tsx,css}'",
    "stylelint:fix": "stylelint --fix '**/*.{tsx,css}'",
    "test": "vitest --config ./vite.config.ts",
    "tsc:watch": "tsc --watch",
    "verify": "${npm_execpath} run lint-and-check-types && vitest run --config ./vite.config.ts && ${npm_execpath} run e2e"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@hookform/resolvers": "5.2.2",
    "@navikt/aksel-icons": "8.9.0",
    "@navikt/ds-css": "8.9.0",
    "@navikt/ds-react": "8.9.0",
    "@tanstack/react-query": "5.96.0",
    "@tanstack/react-router": "1.168.10",
    "axios": "1.15.0",
    "date-fns": "4.1.0",
    "dompurify": "3.4.0",
    "fuse.js": "7.1.0",
    "immer": "11.1.4",
    "lodash": "4.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-pdf": "10.4.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@navikt/aksel-stylelint": "8.9.0",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query-devtools": "5.96.0",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/router-vite-plugin": "1.166.27",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "4.17.24",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "happy-dom": "20.8.9",
    "jsdom": "29.0.1",
    "lint-staged": "16.4.0",
    "postcss-styled-syntax": "0.7.1",
    "stylelint": "17.6.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.2",
    "vite": "7.3.2",
    "vitest": "4.1.2"
  }
}
